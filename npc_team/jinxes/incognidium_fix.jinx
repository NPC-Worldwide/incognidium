#!/usr/bin/env npc
jinx_name: incognidium_fix
description: Apply fixes based on vision analysis from most recent QA run

inputs: []

steps:
  - name: load_and_fix
    engine: python
    code: |
      import subprocess, json, os, glob
      from datetime import datetime
      import pyarrow.parquet as pq

      repo = "/home/caug/incognidium"

      # Find today's QA run data
      today = datetime.now().strftime('%Y-%m-%d')
      qa_dir = f"/tmp/incognidium_qa/{today}"

      vision_problems = []

      if not os.path.exists(qa_dir):
          output = f"No QA data found for {today}"
          context['fixed'] = []
          context['failed'] = []
      else:
          # Scan all parquet files for vision data with issues
          parquet_files = glob.glob(f"{qa_dir}/*.parquet")

          for pf in parquet_files:
              try:
                  table = pq.read_table(pf)
                  df = table.to_pandas()

                  if 'vision_incognidium' not in df.columns or len(df) == 0:
                      continue

                  v_str = df['vision_incognidium'].iloc[0]
                  site_name = df['site_name'].iloc[0] if 'site_name' in df.columns else os.path.basename(pf).replace('.parquet', '')
                  url = df['url'].iloc[0] if 'url' in df.columns else ''

                  try:
                      v = json.loads(v_str) if isinstance(v_str, str) else v_str
                  except:
                      v = {"raw": str(v_str)[:200]}

                  if isinstance(v, dict) and (v.get('error') or v.get('issues', [])):
                      vision_problems.append({
                          "site": site_name,
                          "url": url,
                          "issues": v.get('issues', [])[:3]
                      })
              except Exception as e:
                  continue

          if not vision_problems:
              output = f"No issues found in {len(parquet_files)} sites from today's run."
              context['fixed'] = []
              context['failed'] = []
          else:
              issues_str = "\n\n".join([f"Site: {p['site']}\nIssues: {p['issues']}" for p in vision_problems[:5]])
              codebase = """
              crates/incognidium-layout: layout engine, box sizing, width calculations
              crates/incognidium-css: CSS parsing
              crates/incognidium-style: style resolution, computed styles
              crates/incognidium-paint: text rendering, colors
              """
              recent = subprocess.run(["git", "log", "--oneline", "-5"], cwd=repo, capture_output=True, text=True).stdout
              prompt = f"""
              Fix incognidium browser engine issues. Repo at {repo}.

              Recent changes:
              {recent}

              {issues_str}

              Codebase structure:
              {codebase}

              Fix the rendering issues. Use edit_file to make changes.
              """.strip()

              try:
                  from npcpy.npc_compiler import Team
                  team = Team(team_path=os.path.join(repo, 'npc_team'))
                  renderer = team.npcs.get('renderer')
                  if not renderer:
                      output = "Renderer NPC not found in team"
                  else:
                      team_jinxes = team.jinxes_dict if hasattr(team, 'jinxes_dict') else None
                      messages = [{"role": "user", "content": prompt}]
                      all_outputs = []
                      for i in range(50):
                          try:
                              followup = "Continue fixing the rendering issues. Return the next action as JSON with action, jinx_name, and inputs fields." if i > 0 else prompt
                              result = renderer.check_llm_command(
                                  followup,
                                  messages=messages,
                                  context=context,
                                  jinxes=team_jinxes
                              )
                              if isinstance(result, dict):
                                  messages = result.get('messages', messages)
                                  all_outputs.append(str(result.get('output', '')))
                                  jinx_calls = result.get('jinx_calls', [])
                                  if not jinx_calls:
                                      break
                              else:
                                  all_outputs.append(f"Non-dict result: {str(result)[:200]}")
                                  break
                          except Exception as loop_e:
                              import traceback
                              all_outputs.append(f"Iteration {i} error: {str(loop_e)[:200]}")
                              all_outputs.append(traceback.format_exc()[:500])
                              break
                      agent_output = "\n".join(all_outputs)

                      status = subprocess.run(["git", "status", "--porcelain"], cwd=repo, capture_output=True, text=True)
                      modified = [line[3:] for line in status.stdout.strip().split('\n') if line.startswith(' M ')]
                      context['fixed'] = modified
                      context['failed'] = []
                      output = f"Agent done. Modified {len(modified)} files for {len(vision_problems)} sites.\n{agent_output}"
              except Exception as e:
                  context['fixed'] = []
                  context['failed'] = [{"reason": str(e)[:500]}]
                  output = f"Agent failed: {e}"
